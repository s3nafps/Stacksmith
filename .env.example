DATABASE_URL="file:./dev.db"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-value"

ENCRYPTION_KEY="replace-with-a-long-random-value"
TOKEN_ENCRYPTION_KEY="replace-with-a-64-character-hex-key"

ENABLE_DEMO_AUTH="true"
NEXT_PUBLIC_ENABLE_DEMO_AUTH="true"

ENABLE_RUNNER_SIMULATOR="true"

MOCK_GITHUB_API="true"
NEXT_PUBLIC_MOCK_GITHUB_API="true"
NEXT_PUBLIC_GITHUB_APP_NAME="stacksmith"

ENABLE_MOCK_BILLING="false"
ALLOW_DEMO_PRODUCTION="false"

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_WEBHOOK_SECRET=""
